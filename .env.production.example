# Publish the frontend container only on localhost by default.
# Put Nginx / Caddy / Traefik in front for public HTTPS traffic.
PUBLIC_BIND_IP=127.0.0.1
PUBLIC_HTTP_PORT=8080

# Allowed browser origins for the backend in production
CORS_ORIGINS=https://your-domain.com

# Optional PostgreSQL override
POSTGRES_DB=codefolio
POSTGRES_USER=codefolio
POSTGRES_PASSWORD=change-me
POSTGRES_POOL_MIN_SIZE=1
POSTGRES_POOL_MAX_SIZE=10
