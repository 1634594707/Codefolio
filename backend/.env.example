# ============================================================
# Codefolio – Environment Configuration Example
# Copy this file to .env and fill in your values.
# ============================================================

# ----------------------------------------------------------
# GitHub API
# ----------------------------------------------------------
GITHUB_TOKEN=your_github_personal_access_token_here

# ----------------------------------------------------------
# AI / LLM API  (OpenAI-compatible: DeepSeek, Volcengine, etc.)
# ----------------------------------------------------------
AI_API_KEY=your_ai_api_key_here
AI_API_BASE_URL=https://api.deepseek.com/v1
AI_MODEL=deepseek-chat
AI_REQUEST_TIMEOUT=60.0

# ----------------------------------------------------------
# Redis
# ----------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_DB=0

# ----------------------------------------------------------
# CORS Origins (comma-separated)
# ----------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ----------------------------------------------------------
# General Cache TTL (seconds)
# ----------------------------------------------------------
GITHUB_CACHE_TTL=86400    # 24 hours
AI_CACHE_TTL=604800       # 7 days

# ----------------------------------------------------------
# Repository data – differential TTL strategy (Req 13.3)
# ----------------------------------------------------------
REPOSITORY_METADATA_TTL=3600      # 1 hour  – repo metadata
REPOSITORY_README_TTL=21600       # 6 hours – README content
REPOSITORY_STAR_HISTORY_TTL=86400 # 24 hours – star history

# ----------------------------------------------------------
# Benchmark endpoint rate limiting (Req 20.5)
# ----------------------------------------------------------
BENCHMARK_RATE_LIMIT_MAX_REQUESTS=10   # max requests per sliding window
BENCHMARK_RATE_LIMIT_WINDOW_SECONDS=60 # window size in seconds

# ----------------------------------------------------------
# LLM narrative generation
# ----------------------------------------------------------
LLM_NARRATIVE_ENABLED=true
LLM_MAX_README_CHARS_PER_REPO=12000  # README truncation limit per repo

# ----------------------------------------------------------
# Database
# ----------------------------------------------------------
# DATABASE_PATH=/path/to/custom/codefolio.db
